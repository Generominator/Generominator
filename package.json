{
    "name": "generominator",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "prepare": "husky",
        "precommit": "eslint .",
        "prettier": "prettier --write .",
        "test": "vitest",
        "postinstall": "husky install"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/d3-delaunay": "^6.0.4",
        "@types/node": "^25.3.2",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.182.0",
        "@vitest/web-worker": "^4.0.18",
        "canvas": "^3.2.1",
        "eslint": "^9.39.2",
        "globals": "^17.0.0",
        "husky": "^9.1.7",
        "jsdom": "^27.4.0",
        "lint-staged": "^16.1.2",
        "prettier": "^3.6.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.52.0",
        "vite": "^7.2.4",
        "vitest": "^4.0.18"
    },
    "lint-staged": {
        "**/*.{ts,tsx}": [
