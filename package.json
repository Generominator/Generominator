        "fs": "^0.0.1-security",
        "jiti": "^2.6.1",
        "rand-seed": "^3.0.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "string-width": "^8.1.0",
        "three": "^0.182.0",
        "tracery-grammar": "^2.8.4",
        "vader-sentiment": "^1.1.3"
    }
